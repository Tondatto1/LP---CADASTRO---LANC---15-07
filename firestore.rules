rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function incoming() { return request.resource.data; }
    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'email', 'whatsapp', 'registeredAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.whatsapp is string && data.whatsapp.size() > 0 && data.whatsapp.size() <= 30 &&
             data.registeredAt is string && data.registeredAt.size() <= 50;
    }

    match /registrations/{registrationId} {
      allow read: if false;
      allow create: if isValidRegistration(incoming());
      allow update, delete: if false;
    }
  }
}
